<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="25dp"
    app:cardElevation="20dp"
    android:layout_margin="16dp"
    android:backgroundTint="@color/bg_dark_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_main_gradient">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QUẢN LÝ BÀI HÁT"
            android:textColor="@color/neon_teal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"
            android:shadowColor="@color/neon_pink"
            android:shadowRadius="8"/>

        <EditText
            android:id="@+id/edtDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:hint="Tên bài hát"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtDialogArtist"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:hint="Tên ca sĩ"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtDialogGenre"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:hint="Thể loại (Pop, Rap...)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtDialogCover"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:hint="Link Ảnh bìa (URL)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtDialogMp3"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:hint="Link Nhạc (URL)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtDialogLyrics"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_edittext_glass"
            android:textColor="#FFF"
            android:textColorHint="@color/text_secondary"
            android:padding="16dp"
            android:gravity="top|start"
            android:hint="Dán lời bài hát chuẩn LRC vào đây (Tùy chọn)..."
            android:inputType="textMultiLine"
            android:layout_marginBottom="24dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogSave"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="LƯU THAY ĐỔI"
            android:textColor="#FFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_neon"
            android:textSize="16sp"
            android:elevation="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>